@using Inventory.Repository.Paging;
@using Inventory.ViewModel.Product
@model PageResult<ProductTypeViewModel>
@{
    ViewData["Title"] = "Index";
}

<div class="row">
    <div class="col-6">
        Add New Product Type
        <a asp-action="Create" class="btn btn-primary">Add</a>
    </div>
    <div class="col-4">
        <partial name="_search" />
    </div>
    <div class="row">
        <table class="table">
            <thead>
                <tr>
                    <th>
                        Product - Type Id
                    </th>
                    <th>
                        Title
                    </th>
                    <th>
                        Description
                    </th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach(var item in Model)
                {                    
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.ProductTypeId)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.ProductTypeName)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Description)
                        </td>
                        <td>
                            <a asp-route-id="@item.ProductTypeId" asp-action="Edit" class="btn btn-primary">Edit</a>
                            <a asp-route-id="@item.ProductTypeId" asp-action="Delete" class="btn btn-primary">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

